[core]
	autocrlf = input
	safecrlf = true
	editor = nvim

[color]
	ui = auto

[pull]
	rebase = false

[init]
	defaultBranch = main

[alias]
	st   = status
	co   = checkout
	br   = branch
	lg   = log --oneline --graph --decorate --all
	df   = diff
	dc   = diff --cached
	aa   = add --all
	cm   = commit -m
	undo = reset --soft HEAD~1
	rb   = rebase
	ri   = rebase -i
	cp   = cherry-pick
	sh   = stash
	sp   = stash pop
